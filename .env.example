POSTGRES_USER=caspi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=caspi

DATABASE_URL=postgresql+asyncpg://caspi:changeme@db:5432/caspi

SCRAPER_URL=http://scraper:3001

ISRACARD_ID=
ISRACARD_CARD6_DIGITS=
ISRACARD_PASSWORD=

# Max calendar months for Isracard full-range bulk sync (omit end_date). 0 = no limit. Default 120.
ISRACARD_FULL_SYNC_MAX_MONTHS=120

# Optional JSON overrides for Isracard rate limiting inside the scraper container (see scraper/src/index.js).
# ISRACARD_RATE_LIMIT_JSON={"initialDelay":3000,"maxDelay":120000,"recycleBrowserOnBlock":true,"maxBrowserRecycles":2}

# Auto-scrape: background job that scrapes the last N days every interval to keep the DB fresh.
AUTO_SCRAPE_ENABLED=true
AUTO_SCRAPE_INTERVAL_MINUTES=60
AUTO_SCRAPE_LOOKBACK_DAYS=2

# Auth: enforced when ENVIRONMENT=production (see docker-compose.yml) or AUTH_FORCE_ENABLE=true (local test)
ENVIRONMENT=development
AUTH_FORCE_ENABLE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_EMAIL=
SESSION_SECRET=
PUBLIC_APP_URL=http://localhost:3000
# Must match an Authorized redirect URI in Google Cloud (exact string: https://<host><path>).
OAUTH_GOOGLE_REDIRECT_PATH=/auth/callback
# Optional: allow OAuth/public redirects when X-Forwarded-Host comes from a tunnel
PUBLIC_APP_TRUSTED_HOSTS=
PUBLIC_APP_TRUSTED_HOST_SUFFIXES=.ngrok-free.dev,.ngrok.io,.ngrok.app
SESSION_COOKIE_SECURE=false
