POSTGRES_USER=caspi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=caspi

DATABASE_URL=postgresql+asyncpg://caspi:changeme@db:5432/caspi

SCRAPER_URL=http://scraper:3001

ISRACARD_ID=
ISRACARD_CARD6_DIGITS=
ISRACARD_PASSWORD=

# Max calendar months for Isracard full-range bulk sync (omit end_date). 0 = no limit. Default 120.
ISRACARD_FULL_SYNC_MAX_MONTHS=120

# Bulk scrape pacing (seconds). Gap between months shrinks after each success; bumps up on failure/block.
# ISRACARD_BULK_COOLDOWN_MIN_SECONDS=10
# ISRACARD_BULK_COOLDOWN_INITIAL_SECONDS=45
# ISRACARD_BULK_COOLDOWN_STEP_DOWN_SECONDS=8
# ISRACARD_BULK_COOLDOWN_MAX_SECONDS=180
# ISRACARD_BULK_COOLDOWN_TICK_SECONDS=2
# ISRACARD_BULK_AUTOMATION_RETRY_SECONDS=120
# ISRACARD_BULK_COOLDOWN_FAILURE_BUMP_SECONDS=25

# Credential encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIALS_ENCRYPTION_KEY=

# Auth: enforced when ENVIRONMENT=production (see docker-compose.yml) or AUTH_FORCE_ENABLE=true (local test)
ENVIRONMENT=development
AUTH_FORCE_ENABLE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_EMAIL=
SESSION_SECRET=
PUBLIC_APP_URL=http://localhost:3000
# Must match an Authorized redirect URI in Google Cloud (exact string: https://<host><path>).
OAUTH_GOOGLE_REDIRECT_PATH=/auth/callback
# Optional: allow OAuth/public redirects when X-Forwarded-Host comes from a tunnel
PUBLIC_APP_TRUSTED_HOSTS=
PUBLIC_APP_TRUSTED_HOST_SUFFIXES=.ngrok-free.dev,.ngrok.io,.ngrok.app
SESSION_COOKIE_SECURE=false
