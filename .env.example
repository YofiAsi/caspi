# Auth: enforced when ENVIRONMENT=production (see docker-compose.yml) or AUTH_FORCE_ENABLE=true (local test)
# ENVIRONMENT=development
# AUTH_FORCE_ENABLE=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_GOOGLE_EMAIL=
# SESSION_SECRET=
# PUBLIC_APP_URL=http://localhost:3000
# Must match an Authorized redirect URI in Google Cloud (exact string: https://<host><path>).
# OAUTH_GOOGLE_REDIRECT_PATH=/auth/callback
# Optional: allow OAuth/public redirects when X-Forwarded-Host comes from a tunnel
# PUBLIC_APP_TRUSTED_HOSTS=
# PUBLIC_APP_TRUSTED_HOST_SUFFIXES=.ngrok-free.dev,.ngrok.io,.ngrok.app
# SESSION_COOKIE_SECURE=false
